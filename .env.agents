# Agent Model Configuration
# Configure which models each agent uses

# Agent #1: Question Decomposer (needs structured JSON output)
# Options: qwen2.5:14b, deepseek-r1:14b, llama3.3:70b
AGENT1_MODEL=qwen2.5:14b

# Agent #2: Schema Scout (needs context understanding)  
# Options: glm4:9b, qwen2.5:14b, deepseek-r1:14b
AGENT2_MODEL=glm4:9b

# Agent #3: SQL Architect (needs SQL generation)
# Options: qwen2.5-coder:14b, deepseek-r1:14b, llama3.3:70b
AGENT3_MODEL=qwen2.5-coder:14b

# Ollama Connection
OLLAMA_HOST=http://localhost:11434

# Fallback model (if agent-specific not set)
OLLAMA_MODEL=qwen2.5:14b
